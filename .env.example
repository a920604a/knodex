# Copy this file to .env and fill in your values

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ebook

# Redis
REDIS_URL=redis://localhost:6379

# Auth (JWT)
SECRET_KEY=changeme-use-a-long-random-string-in-production

# Cloudflare Workers AI + Vectorize
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
CF_VECTORIZE_INDEX_NAME=knodex-chunks

# Firebase (backend service account JSON file path)
FIREBASE_CREDENTIALS_JSON=/run/secrets/firebase-credentials.json

# Firebase (frontend — Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
